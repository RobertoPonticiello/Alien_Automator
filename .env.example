# ==============================================================================
# Alien Mind — variabili d'ambiente
# ==============================================================================
# Copia questo file in `.env` e compila i valori. NON committare `.env`.
#   cp .env.example .env
# ==============================================================================

# -----------------------------------------------------------------------------
# n8n — host e webhook
# -----------------------------------------------------------------------------
# In locale lascia "localhost"/"http". In produzione (o con tunnel ngrok)
# imposta WEBHOOK_URL all'URL pubblico HTTPS — Telegram richiede HTTPS per i webhook.
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_LOG_LEVEL=info

# Chiave di cifratura delle credenziali salvate da n8n.
# OBBLIGATORIA. Generala una sola volta e custodiscila — perdendola perdi tutte
# le credenziali memorizzate. Per generarne una:
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# OpenAI — UNICA credenziale per testo (gpt-5-mini) + immagini (gpt-image-1.5)
# -----------------------------------------------------------------------------
# https://platform.openai.com/api-keys
# NB: per gpt-image-1.5 e' richiesta la verifica dell'organizzazione (~5-10 min).
# gpt-5-mini non richiede verifica, e' disponibile su tutte le organizzazioni.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Telegram — review human-in-the-loop
# -----------------------------------------------------------------------------
# Crea il bot via @BotFather, dettagli in docs/telegram-setup.md (Step 7).
TELEGRAM_BOT_TOKEN=
# Il chat_id personale o del gruppo a cui mandare le bozze.
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Google Drive — storage bozze e approvati
# -----------------------------------------------------------------------------
# ID delle due cartelle Drive (li trovi nell'URL della cartella):
#   https://drive.google.com/drive/folders/<QUESTO_ID>
GOOGLE_DRIVE_FOLDER_ID_DRAFTS=
GOOGLE_DRIVE_FOLDER_ID_APPROVED=

# -----------------------------------------------------------------------------
# ngrok (opzionale, solo dev locale)
# -----------------------------------------------------------------------------
# Necessario per esporre il webhook Telegram quando giri in locale.
# Registra un account gratuito su https://dashboard.ngrok.com e copia l'authtoken.
# Avvia con:  docker compose --profile dev up -d
NGROK_AUTH_TOKEN=
