      "parameters": {
        "language": "javaScript",
        "jsCode": "// UPDATE post status='approved' + approved_at\nconst Database = require('better-sqlite3');\nconst DB_PATH = process.env.QUOTES_DB_PATH || '/data/database/quotes.db';\n\nconst ctx = $('Parse callback + load post').first().json;\n\nconst db = new Database(DB_PATH);\ntry {\n  db.prepare(`\n    UPDATE posts\n    SET status = 'approved', approved_at = CURRENT_TIMESTAMP\n    WHERE id = ?\n  `).run(ctx.post_id);\n} finally {\n  db.close();\n}\n\nreturn [{ json: { ...ctx, action_result: 'approved' } }];\n"
      },
